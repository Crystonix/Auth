localhost {
	# Backend API: strip auth/ prefix before sending to auth-service
	handle_path /auth/* {
		reverse_proxy auth-service:4000
	}

	# PGAdmin: preserve /pgadmin prefix
	handle_path /pgadmin/* {
		reverse_proxy pgadmin:80
	}

	# RedisInsight: preserve /redisinsight prefix
	handle_path /redisinsight/* {
		reverse_proxy redisinsight:5540
	}
	handle {
		reverse_proxy frontend:3000
	}
}
