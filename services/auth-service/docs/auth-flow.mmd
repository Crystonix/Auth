flowchart TB
%% External Trust Zone
subgraph EXT["🌐 External Zone"]
direction TB
B[🧑 Browser]:::ext
O[🌐 Discord OAuth]:::ext
end

%% Internal Trust Zone
subgraph INT["🏢 Internal Zone"]
direction TB
A[🔐 Auth Service - Login/Callback]:::proc
L[🔐 Auth Service - Logout]:::proc
R[(💾 Redis - state/session)]:::store
S[(📦 Internal User DB)]:::store
end

%% Login Flow
B -->|GET /login| A:::untrustedFlow
A -->|Store state + PKCE| R:::internalFlow
A -->|302 redirect to OAuth| O:::untrustedFlow
O -->|User login & consent| A:::untrustedFlow
A -->|Validate state + retrieve PKCE| R:::internalFlow
A -->|Exchange code for token| O:::untrustedFlow
A -->|Fetch user info| O:::untrustedFlow
A -->|Map OAuth user → internal user| S:::internalFlow
A -->|Create session| R:::internalFlow
A -->|Set secure cookie + redirect| B:::untrustedFlow

%% Logout Flow
B -->|GET /logout| L:::untrustedFlow
L -->|Delete session| R:::internalFlow
L -->|Clear cookie| B:::untrustedFlow

%% Session Validation Flow
B -->|Authenticated request with cookie| A:::untrustedFlow
A -->|Validate session| R:::internalFlow
A -->|Load user info| S:::internalFlow
A -->|Return resource| B:::untrustedFlow

%% Styles
classDef ext fill:#f9f,stroke:#333,stroke-width:1px,color:#000
classDef proc fill:#9f9,stroke:#333,stroke-width:1px,color:#000
classDef store fill:#ff9,stroke:#333,stroke-width:1px,color:#000

classDef untrustedFlow stroke:#f00,stroke-width:2px,stroke-dasharray: 5 5
classDef internalFlow stroke:#0a0,stroke-width:2px

